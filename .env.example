DISCORD_TOKEN=your_discord_bot_token_here
PORT=3000

# Boss alert behavior
BOSS_WARNING_MINUTES=10
BOSS_TICKER_MS=60000

# Notice crawler behavior (10 minutes default)
NOTICE_TICKER_MS=600000
# Optional: JSON array for custom feeds
# Example:
# NOTICE_SOURCES_JSON=[{"category":"notice","url":"https://example.com/news"}]
